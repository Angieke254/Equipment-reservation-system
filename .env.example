# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; never commit it.

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-django.core.management.utils.get_random_secret_key

# Set to False in production.
DEBUG=True

# Comma-separated hostnames Django will serve.
# Local dev: 127.0.0.1,localhost
# Production: your real domain, e.g. equipment.example.com,www.equipment.example.com
ALLOWED_HOSTS=127.0.0.1,localhost
